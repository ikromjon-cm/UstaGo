{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS"
  },
  "deploy": {
    "startCommand": "cd backend && gunicorn config.wsgi:application --bind 0.0.0.0:$PORT --workers 4 --timeout 120",
    "healthcheckPath": "/api/v1/health/",
    "healthcheckTimeout": 10,
    "restartPolicyType": "ON_FAILURE"
  }
}
