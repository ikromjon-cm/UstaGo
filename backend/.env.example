# UstaGo Backend — Environment Variables
# Copy to .env and fill in values

# Django
SECRET_KEY=change-this-to-a-long-random-string
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Database
DATABASE_URL=postgres://ustago:ustago@localhost:5432/ustago

# Redis / Cache
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000

# Payment Providers
PAYME_MERCHANT_ID=
PAYME_SECRET_KEY=
CLICK_MERCHANT_ID=
CLICK_SECRET_KEY=
UZUM_MERCHANT_ID=
UZUM_SECRET_KEY=
STRIPE_PUBLIC_KEY=
STRIPE_SECRET_KEY=

# SMS / Notifications
ESKIZ_TOKEN=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
TELEGRAM_BOT_TOKEN=

# AI
OPENAI_API_KEY=

# Firebase Push Notifications
FIREBASE_CREDENTIALS=

# Maps
GOOGLE_MAPS_API_KEY=

# Storage (AWS S3)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_STORAGE_BUCKET_NAME=ustago-media
AWS_S3_REGION_NAME=eu-central-1

# Monitoring
SENTRY_DSN=
