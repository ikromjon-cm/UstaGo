# UstaGo Production Settings
# Copy to .env and fill in values

# Django
DJANGO_SECRET_KEY=change-this-to-a-long-random-string
DJANGO_SETTINGS_MODULE=config.settings
DJANGO_ALLOWED_HOSTS=.ustago.uz,localhost
DJANGO_DEBUG=False

# Database
DATABASE_URL=postgres://ustago:ustago@localhost:5432/ustago

# Redis / Cache
REDIS_URL=redis://localhost:6379/0

# CORS
CORS_ALLOWED_ORIGINS=https://ustago.uz,https://admin.ustago.uz

# OpenAI
OPENAI_API_KEY=sk-your-openai-api-key

# JWT
JWT_ACCESS_TOKEN_LIFETIME=60
JWT_REFRESH_TOKEN_LIFETIME=43200

# Email (for OTP)
EMAIL_HOST=smtp.sendgrid.net
EMAIL_PORT=587
EMAIL_HOST_USER=apikey
EMAIL_HOST_PASSWORD=your-sendgrid-api-key
EMAIL_USE_TLS=True
DEFAULT_FROM_EMAIL=noreply@ustago.uz

# Storage
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_STORAGE_BUCKET_NAME=ustago-media
AWS_S3_REGION_NAME=eu-central-1

# Phone verification (SMS provider)
SMS_PROVIDER=eskiz
ESKIZ_EMAIL=your@email.com
ESKIZ_PASSWORD=your-eskiz-password
